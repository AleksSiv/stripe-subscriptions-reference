    "description": "Reference implementation of recurring Stripe subscriptions on Laravel + Cashier with idempotent webhook handling. By Bineks.",
    "keywords": ["laravel", "stripe", "cashier", "subscriptions", "webhooks", "idempotency"],
    "license": "MIT",
    "require": {
